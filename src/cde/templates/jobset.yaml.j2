{# Default JobSet template. Edit freely.

   Substitutions provided to this template by `cde run`:
     run_id              user-supplied tag (e.g. v140)
     image               full image path including tag (cde-<sha7>)
     team                from cde.yaml
     value_class         from defaults / overrides
     declared_minutes    from defaults / overrides
     namespace           resolved from team-quota ConfigMap
     priority_class      resolved from team-quota ConfigMap
     tpu_type            from defaults / overrides
     num_slices          from defaults / overrides
     overrides           free-form dict of --set values
     env                 list of {name, value} dicts merged from --env

#}
apiVersion: jobset.x-k8s.io/v1alpha2
kind: JobSet
metadata:
  name: {{ run_id }}
  namespace: {{ namespace }}
  labels:
    kueue.x-k8s.io/queue-name: lq
    team: {{ team }}
    value-class: {{ value_class }}
    declared-duration-minutes: "{{ declared_minutes }}"
    cde.io/run-id: {{ run_id }}
spec:
  failurePolicy:
    maxRestarts: 0
  replicatedJobs:
  - name: slice
    replicas: {{ num_slices }}
    template:
      spec:
        parallelism: 16
        completions: 16
        backoffLimit: 0
        template:
          metadata:
            labels:
              # Kueue propagates pod-template labels onto the Workload object;
              # declared-duration-minutes MUST appear here for the time-limit
              # controller to read it.
              declared-duration-minutes: "{{ declared_minutes }}"
              cde.io/run-id: {{ run_id }}
          spec:
            priorityClassName: {{ priority_class }}
            restartPolicy: Never
            nodeSelector:
              cloud.google.com/gke-tpu-accelerator: tpu7x
              cloud.google.com/gke-tpu-topology: "4x4x4"
            containers:
            - name: main
              image: {{ image }}
              imagePullPolicy: Always
              command: ["/bin/bash", "-c"]
              args:
                - |
                  python train.py {% for k, v in overrides.items() %}--{{ k }}={{ v }} {% endfor %}
              env:
              - name: CDE_RUN_ID
                value: "{{ run_id }}"
              {%- for e in env %}
              - name: {{ e.name }}
                value: "{{ e.value }}"
              {%- endfor %}
              resources:
                limits:
                  google.com/tpu: "4"
