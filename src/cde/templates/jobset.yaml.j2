{# Default JobSet template. Edit freely.

   Substitutions provided to this template by `cde run`:
     run_id              user-supplied tag (e.g. v140)
     image               full image path including tag (cde-<sha7>)
     team                from cde.yaml
     value_class         from cde.yaml defaults / --value-class
     declared_minutes    from cde.yaml defaults / --declared-minutes
     namespace           team-<team> by default; override via cde.yaml
     priority_class      <namespace>-priority by default; override via cde.yaml
     tpu_type            from cde.yaml defaults
     num_slices          from cde.yaml defaults / --num-slices
     overrides           dict of effective --set values (project defaults +
                         --inherit'd parent + this run's --set, last wins).
                         Booleans set via --flag/--no-flag come through as
                         Python True/False — render as bare flags, not key=value.
                         Convention: keys starting with `_` are
                         orchestration-only (consumed elsewhere in this
                         template, e.g. `_image_override`); the default
                         python-args loop below skips them so they don't
                         leak as `--_foo=...` flags into train.py.
     profile_dir         non-empty when `cde run --profile` was passed
     env                 list of {name, value} dicts cde injected (e.g.
                         JAX_PROFILER_DIR when --profile was used)
#}
apiVersion: jobset.x-k8s.io/v1alpha2
kind: JobSet
metadata:
  name: {{ run_id }}
  namespace: {{ namespace }}
  labels:
    kueue.x-k8s.io/queue-name: lq
    team: {{ team }}
    value-class: {{ value_class }}
    declared-duration-minutes: "{{ declared_minutes }}"
    cde.io/run-id: {{ run_id }}
spec:
  failurePolicy:
    maxRestarts: 0
  replicatedJobs:
  - name: slice
    replicas: {{ num_slices }}
    template:
      spec:
        parallelism: 16
        completions: 16
        backoffLimit: 0
        template:
          metadata:
            annotations:
              # Kueue topology-aware scheduling. Required when the cluster's
              # ResourceFlavor sets spec.topologyName (common on TPU clusters).
              # Without these annotations, the Workload sits forever with
              # QuotaReserved=False, reason=Pending, message='couldn't assign
              # flavors to pod set ...: Flavor "..." supports only
              # TopologyAwareScheduling'. Value is the node label that
              # identifies a topology unit; on GKE TPU that is the slice.
              # If your cluster's flavor has no topologyName, you can delete
              # these two lines safely.
              kueue.x-k8s.io/podset-required-topology: cloud.google.com/gke-tpu-topology
              kueue.x-k8s.io/podset-slice-required-topology: cloud.google.com/gke-tpu-topology
            labels:
              # Kueue propagates pod-template labels onto the Workload object;
              # declared-duration-minutes MUST appear here for the time-limit
              # controller to read it.
              declared-duration-minutes: "{{ declared_minutes }}"
              cde.io/run-id: {{ run_id }}
          spec:
            priorityClassName: {{ priority_class }}
            restartPolicy: Never
            nodeSelector:
              cloud.google.com/gke-tpu-accelerator: tpu7x
              cloud.google.com/gke-tpu-topology: "4x4x4"
            containers:
            - name: main
              image: {{ image }}
              imagePullPolicy: Always
              command: ["/bin/bash", "-c"]
              args:
                - |
                  python train.py {% for k, v in overrides.items() if not k.startswith('_') -%}
                  {%- if v is sameas true %}--{{ k }} {% elif v is sameas false %}{# omitted: --no-flag {{ k }} #}{% else %}--{{ k }}={{ v }} {% endif %}
                  {%- endfor %}
              env:
              - name: CDE_RUN_ID
                value: "{{ run_id }}"
              {%- for e in env %}
              - name: {{ e.name }}
                value: "{{ e.value }}"
              {%- endfor %}
              resources:
                limits:
                  google.com/tpu: "4"
